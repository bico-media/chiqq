{
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100,
		"bracketSpacing": false
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "es5",
			"arrowParentheses": "asNeeded"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"trailingCommas": "none"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"correctness": "error",
			"suspicious": "error"
		}
	},
	"files": {
		"includes": ["{.,src,test}/**/*.{ts,js,json,md}"]
	},
	"overrides": [
		{
			"includes": ["src/index.ts"],
			"linter": {
				"rules": {
					"style": {
						"useConst": "off"
					},
					"suspicious": {
						"noBitwiseOperators": "off",
						"noExplicitAny": "off",
						"noImplicitAnyLet": "off",
						"noEvolvingTypes": "off",
						"noAsyncPromiseExecutor": "off",
						"useAwait": "off"
					}
				}
			}
		},
		{
			"includes": ["test/**", "examples/**"],
			"linter": {
				"rules": {
					"correctness": {
						"useImportExtensions": "off"
					},
					"suspicious": {
						"useAwait": "off",
						"noExplicitAny": "off",
						"noConsole": "off"
					}
				}
			}
		}
	]
}
