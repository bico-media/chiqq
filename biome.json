{
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100,
		"bracketSpacing": false
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "es5",
			"arrowParentheses": "asNeeded"
		}
	},
	"json": {
		"formatter": {"indentStyle": "tab"}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"correctness": "error",
			"suspicious": "error"
		}
	},
	"files": {
		"includes": ["{.,src,test}/**/*.{ts,js,json}"]
	}
}
