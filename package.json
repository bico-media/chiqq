{
	"name": "chiqq",
	"version": "1.0.0",
	"description": "A modern queue for async tasks with concurrency control and retry logic",
	"main": "dist/chiqq.es5.js",
	"module": "dist/chiqq.es6.js",
	"types": "index.d.ts",
	"files": [
		"dist",
		"mod.ts"
	],
	"scripts": {
		"build": "bun -e 'await Bun.$`rm -rf dist && mkdir dist`' && bun run build-es5 && bun run build-es6 && bun run build-types && rm -f dist/index.new.d.ts dist/types.d.ts dist/index.d.ts.map",
		"build-es5": "bun build src/index.ts --outfile dist/chiqq.es5.js --format cjs",
		"build-es6": "bun -e 'await Bun.$`cp src/index.ts dist/chiqq.es6.js`'",
		"build-types": "tsc src/index.ts --declaration --emitDeclarationOnly --outDir dist --skipLibCheck --sourceMap false",
		"dev": "bun --watch src/index.ts",
		"lint": "biome check",
		"format": "biome format --write",
		"test-format": "biome format",
		"test": "bun test"
	},
	"keywords": [
		"queue",
		"async",
		"concurrency",
		"retry",
		"typescript"
	],
	"author": "Mathias Wulff",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.3.4",
		"bun-types": "^1.3.1",
		"typescript": "^4.8.4"
	}
}
